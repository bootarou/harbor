// Prisma schema for the Symbol(XYM) tipping blog.
// NOTE: 秘密鍵・ニーモニックはサーバーに保存しない。User に保持するのは公開アドレス(xymAddress)のみ。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  displayName  String
  avatarUrl    String?
  bio          String?
  xAccount     String?
  xymAddress   String? // 公開アドレスのみ。秘密鍵は保存しない
  tokushoho    String? // 特定商取引法に基づく表記（テキスト/Markdown・HTML不可）
  salesTerms   String? // 利用規約・販売条件（テキスト/Markdown・HTML不可）
  createdAt    DateTime @default(now())

  posts     Post[]
  comments  Comment[]
  sentTips  Tip[]      @relation("SentTips")
  purchases Purchase[] @relation("Purchases")
  reactions Reaction[] @relation("Reactions")
  thanksSent     Thanks[] @relation("ThanksSent")
  thanksReceived Thanks[] @relation("ThanksReceived")

  following Follow[] @relation("Following") // この人がフォローしている関係
  followers Follow[] @relation("Followers") // この人がフォローされている関係
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String // フォローする側
  followingId String // フォローされる側
  follower    User     @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followingId])
}

model Post {
  id          String   @id @default(cuid())
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  title       String
  contentHTML String   @db.Text // 通常公開: 全文 / 販売公開: 試し読み(無料)部分
  coverImage  String?
  published   Boolean  @default(false)
  tags        String[] @default([])
  publishAt   DateTime? // 公開日時。未来なら未公開扱い

  // 販売公開（有料記事）関連
  paid          Boolean  @default(false)
  paidHtml      String?  @db.Text // 購入者のみ閲覧できる有料部分
  priceAmount   Decimal?
  priceCurrency String? // "XYM" のみ許可（当面）
  sellerAddress String? // 販売者(投稿者)の受取アドレス

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments  Comment[]
  tips      Tip[]
  purchases Purchase[]
  reactions Reaction[]
  thanks    Thanks[]

  @@index([authorId])
  @@index([published, createdAt])
  @@index([tags], type: Gin)
}

model Reaction {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("Reactions", fields: [userId], references: [id], onDelete: Cascade)
  type      String // like / empathy / helpful / fun / thanks
  createdAt DateTime @default(now())

  thanks Thanks? // このリアクションに対して送られた Thanks（任意・1件）

  @@unique([postId, userId, type])
  @@index([postId])
  @@index([userId])
}

model Thanks {
  id              String    @id @default(cuid())
  reactionId      String?   @unique
  reaction        Reaction? @relation(fields: [reactionId], references: [id], onDelete: SetNull)
  postId          String
  post            Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  senderUserId    String?
  sender          User?     @relation("ThanksSent", fields: [senderUserId], references: [id], onDelete: SetNull)
  receiverUserId  String?
  receiver        User?     @relation("ThanksReceived", fields: [receiverUserId], references: [id], onDelete: SetNull)
  senderAddress   String
  receiverAddress String
  thanksType      String // thanks / super_thanks
  amount          Decimal
  currency        String
  txHash          String    @unique
  status          String // confirmed / pending
  jpyRate         Decimal?
  createdAt       DateTime  @default(now())

  @@index([receiverUserId])
  @@index([senderUserId])
  @@index([postId])
}

model Purchase {
  id            String   @id @default(cuid())
  postId        String
  post          Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  buyerUserId   String?
  buyerUser     User?    @relation("Purchases", fields: [buyerUserId], references: [id], onDelete: SetNull)
  buyerAddress  String
  sellerAddress String
  amount        Decimal
  currency      String
  txHash        String   @unique
  confirmed     Boolean  @default(false)
  jpyRate       Decimal? // 記録時点の XYM/JPY レート（税務の円換算用）
  purchasedAt   DateTime @default(now())

  @@index([postId])
  @@index([buyerUserId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String   @db.Text
  createdAt DateTime @default(now())

  @@index([postId])
  @@index([userId])
}

model Tip {
  id          String   @id @default(cuid())
  postId      String
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  fromAddress String
  toAddress   String
  amount      Decimal
  txHash      String   @unique
  // 送信者ユーザー（履歴表示用。退会等で消えても Tip 自体は残す）
  fromUserId  String?
  fromUser    User?    @relation("SentTips", fields: [fromUserId], references: [id], onDelete: SetNull)
  anonymous   Boolean  @default(false)
  message     String?
  // false: クライアント申告（確認中） / true: ノードのポーリングでオンチェーン確定
  confirmed   Boolean  @default(false)
  jpyRate     Decimal? // 記録時点の XYM/JPY レート（税務の円換算用）
  confirmedAt DateTime @default(now())

  @@index([postId])
  @@index([fromUserId])
}
