# docker compose 用の環境変数サンプル。
#   cp .env.docker.example .env   して値を埋め、`docker compose up -d --build`
#
# 注意: DATABASE_URL は compose 側で db サービス向けに自動生成されるため、ここでは設定不要。
#       （アプリ単体起動用 .env.example の localhost 設定はコンテナでは使わない）

# ===== PostgreSQL（db サービス）=====
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=nagexym

# ===== 認証（必須）=====
# 生成: openssl rand -base64 32
AUTH_SECRET=
# リバースプロキシ / Cloudflare Tunnel 背後では true 推奨
AUTH_TRUST_HOST=true
# 通常は自動検出。必要時のみ。例: https://your-domain.example.com
AUTH_URL=

# ===== 公開ポート =====
PORT=3000

# ===== Symbol（ビルド時にクライアントへ焼き込まれる。変更時は --build 必須）=====
NEXT_PUBLIC_SYMBOL_NETWORK=testnet
NEXT_PUBLIC_SYMBOL_NODE_URL=https://sym-test-01.opening-line.jp:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# ヘッダーのサイト名（未設定なら "⚓Harbor"）
NEXT_PUBLIC_SITE_NAME=⚓Harbor

# ===== 着金/購入の自動確定 cron =====
# CRON_SECRET を設定すると cron サービスが定期的に poll-tips を叩き、投げ銭・購入を
# 自動で「確定」にする（未設定だと受信者の「着金を同期」/送金者の確認待ちになる）。
CRON_SECRET=
# ポーリング間隔（秒）。既定 300（5分）。
POLL_INTERVAL=300

# ===== 通報通知メール（任意）=====
REPORT_NOTIFY_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ===== 画像ストレージ S3互換（任意。未設定ならローカル保存）=====
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
NEXT_PUBLIC_S3_PUBLIC_URL=
