# ===== Database (PostgreSQL) =====
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/nagexym?schema=public"

# ===== サーバー起動ポート / ホスト =====
# `npm run dev` / `npm start` の待ち受けポート（既定: 3000）。
# Next.js は .env の PORT を直接読まないため、scripts/next-with-env.mjs 経由で反映している。
# シェルで `PORT=4000 npm run dev` のように指定した場合はそちらが優先される。
PORT="3000"
# 待ち受けホスト（既定: 0.0.0.0 / 全インターフェース）。任意。
# HOSTNAME="0.0.0.0"

# ===== サイトURL（OG/メタデータ用。本番は実際のURL） =====
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ===== ヘッダーのサイト名（未設定なら "⚓Harbor"）。NEXT_PUBLIC_* はビルド時に焼き込まれる =====
NEXT_PUBLIC_SITE_NAME="⚓Harbor"

# ===== Auth.js (NextAuth v5) =====
# 本番では十分にランダムな値を設定すること: `npx auth secret` または `openssl rand -base64 32`
AUTH_SECRET="replace-with-a-long-random-secret"
# 通常は自動検出されるため任意。リバースプロキシ下などで必要な場合のみ設定。
# AUTH_URL="https://your-domain.example.com"
# リバースプロキシ / Cloudflare Tunnel 背後でホストする場合は必須（ホスト検出のため）。
AUTH_TRUST_HOST=true

# ===== Symbol (Phase 5 以降で使用 / 開発は常にテストネット) =====
NEXT_PUBLIC_SYMBOL_NETWORK="testnet"
# ノードURL。カンマ区切りで複数指定すると、先頭から順にフェイルオーバーする。
# 例: "https://node-a:3001,https://node-b:3001,https://node-c:3001"
NEXT_PUBLIC_SYMBOL_NODE_URL="https://sym-test-01.opening-line.jp:3001"

# 投げ銭着金ポーリング(/api/cron/poll-tips)の Bearer シークレット（外部cron用）
CRON_SECRET="replace-with-a-random-cron-secret"

# ===== 通報通知メール =====
# 通報があった際の通知先
REPORT_NOTIFY_EMAIL=
# SMTP（未設定なら実送信せずサーバーログに出力。本番では設定すること）
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# ===== 画像ストレージ (S3互換 / Phase 3 以降で使用) =====
S3_ENDPOINT=""
S3_REGION=""
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
NEXT_PUBLIC_S3_PUBLIC_URL=""
