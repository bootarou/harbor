# ===== Database (PostgreSQL) =====
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/nagexym?schema=public"

# ===== サイトURL（OG/メタデータ用。本番は実際のURL） =====
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ===== Auth.js (NextAuth v5) =====
# 本番では十分にランダムな値を設定すること: `npx auth secret` または `openssl rand -base64 32`
AUTH_SECRET="replace-with-a-long-random-secret"
# 通常は自動検出されるため任意。リバースプロキシ下などで必要な場合のみ設定。
# AUTH_URL="http://localhost:3000"

# ===== Symbol (Phase 5 以降で使用 / 開発は常にテストネット) =====
NEXT_PUBLIC_SYMBOL_NETWORK="testnet"
NEXT_PUBLIC_SYMBOL_NODE_URL="https://sym-test-01.opening-line.jp:3001"

# 投げ銭着金ポーリング(/api/cron/poll-tips)の Bearer シークレット（外部cron用）
CRON_SECRET="replace-with-a-random-cron-secret"

# ===== 画像ストレージ (S3互換 / Phase 3 以降で使用) =====
S3_ENDPOINT=""
S3_REGION=""
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
NEXT_PUBLIC_S3_PUBLIC_URL=""
